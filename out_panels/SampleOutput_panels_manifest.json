{
  "version": 1,
  "pipeline": "panels",
  "pipeline_flow": [
    {
      "step": 1,
      "title": "Load raster image",
      "implementation": "preprocess.load_image_bgr, preprocess.load_pdf_page_as_bgr; pipeline.load_input_bgr / panel_dxf_pipeline._load_bgr"
    },
    {
      "step": 2,
      "title": "Convert to grayscale",
      "implementation": "preprocess.preprocess (cv2.cvtColor BGR\u2192GRAY)"
    },
    {
      "step": 3,
      "title": "Apply adaptive thresholding",
      "implementation": "annotation_clean.inks_mask_from_gray (cv2.adaptiveThreshold ADAPTIVE_THRESH_GAUSSIAN_C, THRESH_BINARY_INV)"
    },
    {
      "step": 4,
      "title": "Perform deskewing/alignment",
      "implementation": "preprocess._deskew_gray (invoked from preprocess.preprocess when deskew=True)"
    },
    {
      "step": 5,
      "title": "Remove noise",
      "implementation": "preprocess.preprocess bilateral denoise; skeleton_vectorize.extract_vector_drawing remove_small_objects on foreground before skeletonize"
    },
    {
      "step": 6,
      "title": "Apply morphology closing to reconnect broken lines",
      "implementation": "annotation_clean.suppress_hatches_and_dimensions MORPH_CLOSE on binary ink (when suppress_ruling_lines=True); preprocess._deskew_gray uses a small close on Otsu mask"
    },
    {
      "step": 7,
      "title": "Separate OCR/text layer from geometry layer",
      "implementation": "ocr_extract.extract_text_boxes; optional ocr_llm_correct.correct_text_boxes_ollama / correct_text_boxes_gemini; optional semantic_segment.semantic_prepare_gray_for_vectorize (ONNX classes); annotation_clean.apply_text_masks / apply_text_masks_interior_only before inks_mask_from_gray"
    },
    {
      "step": 8,
      "title": "Detect line segments using LSD/Hough Transform",
      "implementation": "Primary path: skeleton_graph.trace_skeleton_polylines. Alternates: vectorize._legacy_hough_extract_segments (HoughLinesP). Optional supplement: geometry_intel.lsd_extract_segments (cv2.createLineSegmentDetector) via --vectorize-lsd-supplement in vectorize.extract_skeleton_vector_bundle."
    },
    {
      "step": 9,
      "title": "Detect circles/arcs using HoughCircles",
      "implementation": "skeleton_vectorize.detect_circles (optional, off by default): tighter Hough params, rim + **hole-interior** validation on binary ink, hard cap on count. Enable with --skeleton-circles. vector_fit.apply_polyline_fittings for arc / loop-to-CIRCLE when arc fitting is on."
    },
    {
      "step": 10,
      "title": "Detect rectangles and closed polylines",
      "implementation": "Closed loops: skeleton traces with closed=True \u2192 geometry_model.PolylineDef.closed. Orthogonal 4-gons tallied as rectangle_like_polylines (geometry_intel.count_corner_rectangles); no separate DXF RECTANGLE entity type."
    },
    {
      "step": 11,
      "title": "Snap nearby endpoints together",
      "implementation": "vectorize.extract_skeleton_vector_bundle \u2192 _merge_close_endpoints on exploded segments"
    },
    {
      "step": 12,
      "title": "Merge collinear and overlapping lines",
      "implementation": "exploded segments: vectorize._merge_close_endpoints; optional topology_clean.refine_vector_drawing when --python-topology-clean; CAD join/overkill deferred to AutoCAD MCP by default."
    },
    {
      "step": 13,
      "title": "Reconstruct topology graph/connectivity",
      "implementation": "skeleton_graph.skeleton_adjacency_graph + trace_skeleton_polylines; optional topology_repair.extend_free_endpoints_to_intersections (ray hits); cad_geometry_rebuild.vector_drawing_from_healed_segments aligns DXF with healed LINE graph"
    },
    {
      "step": 14,
      "title": "Detect dimensions, arrows, and extension lines",
      "implementation": "Partial: annotation_clean.suppress_hatches_and_dimensions removes long horizontal ruling motifs; no dedicated arrow/dimension classifier."
    },
    {
      "step": 15,
      "title": "Group related entities into drawing parts/blocks",
      "implementation": "pipeline: link_geometry.link_vector_geometry_to_parts + link_parts.PartGroup; panels: panel_split.split_panels then per-crop export"
    },
    {
      "step": 16,
      "title": "Preserve original scaling and coordinates",
      "implementation": "PreprocessResult.original_shape, scale; RunConfig.mm_per_pixel; export_dxf.image_xy_to_dxf consistent Y-flip + scale in manifests"
    },
    {
      "step": 17,
      "title": "Convert primitives into CAD entities (LINE, ARC, CIRCLE, TEXT, etc.)",
      "implementation": "export_dxf._emit_vector_entities: LWPOLYLINE, ARC, CIRCLE, LINE residuals; TEXT via PartGroup label points on part layers"
    },
    {
      "step": 18,
      "title": "Generate structured DXF entities/layers",
      "implementation": "export_dxf.export_merged_dxf / export_part_dxf / export_segments_only (layer-per-part or GEOMETRY/LABEL conventions)"
    },
    {
      "step": 19,
      "title": "Export final DXF file",
      "implementation": "ezdxf writes in export_dxf; paths recorded in *_manifest.json"
    },
    {
      "step": 20,
      "title": "Run post-processing cleanup and validation",
      "implementation": "Default: export rough DXF + ``*_autocad_mcp_recipe.json`` for JOIN / OVERKILL / PEDIT / layers / dimensions in AutoCAD (MCP). Optional in-process: topology_clean, vector_fit, geometry_intel bridge/dedupe (--python-* flags); geometry_intel.geometry_quality_report + manifest warnings."
    }
  ],
  "engineering_intelligence_layers": [
    {
      "layer": "semantic_reasoning",
      "title": "Semantic reasoning",
      "status": "optional",
      "implementation": "engineering_intel_passes.semantic_reasoning_snapshot when --python-engineering-intel; link_geometry / OCR part association at export time always when OCR enabled."
    },
    {
      "layer": "engineering_constraints",
      "title": "Engineering constraints",
      "status": "optional",
      "implementation": "constraint_heal (+ engineering_intel residual snaps) only with --python-constraint-heal and --python-engineering-intel; otherwise defer to AutoCAD constraints/MCP."
    },
    {
      "layer": "topology_intelligence",
      "title": "Topology intelligence",
      "status": "optional",
      "implementation": "topology_repair on segments with --python-topology-segment-repair; topology_intel metrics with --python-engineering-intel; else MCP/CAD for graph cleanup."
    },
    {
      "layer": "cad_regularization",
      "title": "CAD regularization",
      "status": "optional",
      "implementation": "topology_clean / vectorize refinements when --python-*; primary regularization via AutoCAD MCP recipe."
    },
    {
      "layer": "dimension_understanding",
      "title": "Dimension understanding",
      "status": "active",
      "implementation": "annotations_export.dimension_association_bundle: axis hints + OCR\u2194stroke association records + perpendicular extension stubs on DIMENSION_HINT layer (when export enabled); manifest dimension_associations."
    }
  ],
  "reconstruction_roadmap": [
    {
      "stage": 1,
      "title": "Raster acquisition and preprocess",
      "status": "implemented",
      "implementation": "preprocess.preprocess: denoise, deskew, scale; grayscale for ink mask + skeleton."
    },
    {
      "stage": 2,
      "title": "Ink / geometry vs text separation",
      "status": "partial",
      "implementation": "OCR masks + annotation_clean text interior inpainting; dimension text not structured as DIM entities."
    },
    {
      "stage": 3,
      "title": "Primitive extraction (lines, arcs, circles)",
      "status": "partial",
      "implementation": "skeleton_vectorize + vectorize; optional Hough circles (--skeleton-circles); vector_fit arcs; fragments remain without strong reconstruction."
    },
    {
      "stage": 4,
      "title": "Topology repair and graph connectivity",
      "status": "partial",
      "implementation": "topology_repair.repair_exploded_segments; topology_clean.refine_vector_drawing; engineering_intel axis/cluster snaps when enabled (--python-* or --reconstruction shop)."
    },
    {
      "stage": 5,
      "title": "Constraint and orthogonal regularization",
      "status": "partial",
      "implementation": "constraint_heal orthogonal quads; residual snaps in engineering_intel_passes; full constraint solver not implemented."
    },
    {
      "stage": 6,
      "title": "Dimension system reconstruction",
      "status": "partial",
      "implementation": "annotations_export.dimension_association_bundle + DIMENSION_HINT layer; no full extension-line / arrow DIM block model."
    },
    {
      "stage": 7,
      "title": "Semantic entity classification",
      "status": "partial",
      "implementation": "segment_semantics + raster_semantics / ONNX; engineering_intel_extended.symbol_candidates; engineering_reconstruction_suite multilayer bucket expansion."
    },
    {
      "stage": 8,
      "title": "Structured DXF / layer model",
      "status": "implemented",
      "implementation": "export_dxf: LWPOLYLINE, LINE, ARC, CIRCLE, TEXT, layers per part/panel."
    },
    {
      "stage": 9,
      "title": "Native CAD polish (MCP / interactive)",
      "status": "implemented",
      "implementation": "cad_mcp_recipe: JOIN, OVERKILL, PEDIT, layers\u2014assumes reasonable upstream geometry."
    }
  ],
